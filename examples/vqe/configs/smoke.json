{
  "lane": "vqe",
  "problem_label": "N2 CUDA-Q smoke search",
  "run_name": "vqe_n2_cas66_smoke",
  "iterations": 2,
  "candidate_wall_seconds": 5.0,
  "molecule": "N2",
  "chemical_accuracy": 0.001,
  "seed": 7,
  "objective": {
